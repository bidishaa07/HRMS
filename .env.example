# Database and cache
POSTGRES_DB=aurora
POSTGRES_USER=aurora
POSTGRES_PASSWORD=aurora
DATABASE_URL=postgresql+asyncpg://aurora:aurora@postgres:5432/aurora
REDIS_URL=redis://redis:6379/0

# Authentication - replace in production
JWT_SECRET=change-me-to-a-long-random-secret
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=7
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/google/callback
FRONTEND_URL=http://localhost:3000
COOKIE_SECURE=false

# AI
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL_ID=qwen2.5:3b

# Storage and email
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=aurora
MINIO_SECRET_KEY=aurora-secret
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_FROM=people@aurora.local
SENDER_MAIL_ID=people@aurora.local
RELIEVER_MAIL_ID=auto

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
